{
  "multipart": [
    {
      "when": {
        "facing": "north"
      },
      "apply": {
        "model": "ae2lt:block/lightning_simulation_room_off"
      }
    },
    {
      "when": {
        "facing": "east"
      },
      "apply": {
        "model": "ae2lt:block/lightning_simulation_room_off",
        "y": 90
      }
    },
    {
      "when": {
        "facing": "south"
      },
      "apply": {
        "model": "ae2lt:block/lightning_simulation_room_off",
        "y": 180
      }
    },
    {
      "when": {
        "facing": "west"
      },
      "apply": {
        "model": "ae2lt:block/lightning_simulation_room_off",
        "y": 270
      }
    },
    {
      "when": {
        "facing": "north",
        "working": "true"
      },
      "apply": {
        "model": "ae2lt:block/lightning_simulation_room_on"
      }
    },
    {
      "when": {
        "facing": "east",
        "working": "true"
      },
      "apply": {
        "model": "ae2lt:block/lightning_simulation_room_on",
        "y": 90
      }
    },
    {
      "when": {
        "facing": "south",
        "working": "true"
      },
      "apply": {
        "model": "ae2lt:block/lightning_simulation_room_on",
        "y": 180
      }
    },
    {
      "when": {
        "facing": "west",
        "working": "true"
      },
      "apply": {
        "model": "ae2lt:block/lightning_simulation_room_on",
        "y": 270
      }
    }
  ]
}
