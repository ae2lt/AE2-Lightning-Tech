{
  "multipart": [
    {
      "when": {
        "powered": "false"
      },
      "apply": {
        "model": "ae2lt:block/lightning_assembler",
        "y": 90
      }
    },
    {
      "when": {
        "powered": "true"
      },
      "apply": {
        "model": "ae2lt:block/lightning_assembler_powered",
        "y": 90
      }
    },
    {
      "when": {
        "powered": "true",
        "working": "true"
      },
      "apply": {
        "model": "ae2lt:block/lightning_assembler_lightnings"
      }
    }
  ]
}
